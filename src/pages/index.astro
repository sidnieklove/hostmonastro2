---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Høst Møn | Forside">
  <section class="section hero">
    <div class="container hero-grid">
      <div>
        <h1 class="hero-title">Høst Møn</h1>
        <p class="hero-sub">Rå musik. Blød sol. Fælles øjeblikke.</p>
        <div class="hero-actions">
          <a href="/program" class="btn btn-primary">Se program</a>
          <a href="/kob-billet" class="btn btn-secondary">Køb billet</a>
        </div>
        <p>
          En intim musikfestival med fokus på musik, natur og frivilligt fællesskab.
          Designet er inspireret af scrapbook, papirtekstur og håndlavet energi.
        </p>
      </div>

      <div class="poster">
        <div class="poster-strip">
          <span class="kicker">Høst Møn 2026</span>
          <p>Jenny Wilson. Selina Gin. Rigmor. School of X. Hurula.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>
