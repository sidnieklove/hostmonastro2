---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Køb Billet | Høst Møn">
  <section class="ticket-page">
    <header class="frontpage-header">
      <a href="/" class="logo">Høst Møn</a>

      <nav class="main-nav">
        <a href="/program">Program</a>
        <a href="/faellesskab">Fællesskab</a>
        <a href="/om">Om os</a>
        <a href="/kob-billet" class="ticket-btn">Køb Billet</a>
      </nav>
    </header>

    <section class="ticket-content">
      <h1 class="ticket-title">Køb Billet</h1>

      <div class="ticket-prices">
        <div class="ticket-row">
          <span class="ticket-row__label">Partoutbillet:</span>
          <span class="ticket-row__price">1,095,-</span>
        </div>

        <div class="ticket-row">
          <span class="ticket-row__label">Fredag:</span>
          <span class="ticket-row__price">550,-</span>
        </div>

        <div class="ticket-row">
          <span class="ticket-row__label">Lørdag:</span>
          <span class="ticket-row__price">620,-</span>
        </div>
      </div>

      <div class="ticket-cta-wrap">
        <a href="#" class="ticket-cta">Gå til køb</a>
      </div>
    </section>
  </section>
</Layout>